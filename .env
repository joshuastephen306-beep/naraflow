# =============================================
# NARAFLOW - Environment Variables Template
# Copy this to .env and fill in real values
# =============================================

# --- Server ---
NODE_ENV=development
PORT=4000
APP_NAME=NaraFlow
FRONTEND_URL=http://localhost:3000

# --- Database (PostgreSQL) ---
DB_HOST=aws-1-us-east-1.pooler.supabase.com
DB_PORT=6543
DB_NAME=postgres
DB_USER=postgres.zvulfwmfxrtgowcapmck
DB_PASSWORD=Jos11hua11$
DB_SSL=true

# --- JWT ---
JWT_SECRET=NaraFlow2024SecretKey!Victor#Secure
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=NaraFlow2024RefreshKey!Victor#Safe
JWT_REFRESH_EXPIRES_IN=30d

# --- Flutterwave (Primary Payment) ---
FLW_PUBLIC_KEY=FLWPUBK_TEST-xxxxxxxxxxxxxxxxxxxx-X
FLW_SECRET_KEY=FLWSECK_TEST-xxxxxxxxxxxxxxxxxxxx-X
FLW_ENCRYPTION_KEY=your_flutterwave_encryption_key
FLW_WEBHOOK_SECRET=your_flutterwave_webhook_secret
FLW_BASE_URL=https://api.flutterwave.com/v3

# --- Paystack (Secondary Payment) ---
PAYSTACK_PUBLIC_KEY=pk_test_xxxxxxxxxxxxxxxxxxxx
PAYSTACK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxx
PAYSTACK_WEBHOOK_SECRET=your_paystack_webhook_secret
PAYSTACK_BASE_URL=https://api.paystack.co

# --- Email (Nodemailer / SMTP) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_gmail_app_password
EMAIL_FROM=NaraFlow <noreply@naraflow.com>

# --- AWS (Optional - for file storage) ---
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=us-east-1
AWS_S3_BUCKET=naraflow-kyc-docs

# --- OTP / Verification ---
OTP_EXPIRY_MINUTES=10
OTP_LENGTH=6

# --- Rate Limiting ---
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# --- Exchange Rate API ---
# Using exchangerate-api.com (free tier available)
EXCHANGE_RATE_API_KEY=your_exchange_rate_api_key
EXCHANGE_RATE_BASE_URL=https://v6.exchangerate-api.com/v6

# --- App Fee Config ---
TRANSFER_FEE_PERCENT=1.5
TRANSFER_FEE_MIN_USD=1.00
TRANSFER_FEE_MAX_USD=15.00
